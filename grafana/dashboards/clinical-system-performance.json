      "type": "stat",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=~\"/rootfs|/\",fstype!~\"tmpfs|overlay|aufs|squashfs|devtmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=~\"/rootfs|/\",fstype!~\"tmpfs|overlay|aufs|squashfs|devtmpfs\"}))",
          "legendFormat": "Disk",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": { "titleSize": 32, "valueSize": 96 },
        "textMode": "value",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#14b8a6", "value": null },
              { "color": "#eab308", "value": 75 },
              { "color": "#ef4444", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
